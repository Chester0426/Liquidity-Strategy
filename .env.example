# Supabase (database + auth)
# Get these from: Supabase Dashboard → Project Home → Data API popup
# Or use the Supabase Vercel Integration to auto-inject these
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-api-key

# Supabase Vercel Integration auto-injects:
# POSTGRES_URL_NON_POOLING=postgresql://...  (used by auto-migrate script)
# POSTGRES_URL=postgresql://...
# SUPABASE_SERVICE_ROLE_KEY=...              (server-side admin operations)

# No PostHog env vars needed — credentials are hardcoded in src/lib/analytics.ts
# No Stripe — payment not in stack
# No Resend — email not in stack

# Playwright E2E tests
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=testpassword123
